{
  "fieldlink": {
    "version": "1.2",
    "updated": "2026-03-24T00:00:00Z",
    "role": ["shapes", "bridges", "hub"],

    "sources": [
      {
        "name": "rosetta",
        "repo": "https://github.com/JinnZ2/Rosetta-Shape-Core",
        "ref": "main",
        "direction": "bidirectional",
        "paths": [
          "shapes/**/*.json",
          "bridges/**/*.json",
          "data/**/*.json",
          "ontology/**/*.json",
          "schema/core.schema.json",
          "schema/shape.schema.json",
          "atlas/**/*.json"
        ],
        "mounts": [
          { "remote": "bridges/rosetta-bridges.json", "as": "atlas/remote/rosetta/bridges.json" },
          { "remote": "shapes/octahedron.json", "as": "atlas/remote/rosetta/shapes/octahedron.json" },
          { "remote": "data/shape_ontology.json", "as": "atlas/remote/rosetta/shape_ontology.json" },
          { "remote": "data/math_constants.json", "as": "atlas/remote/rosetta/math_constants.json" },
          { "remote": "data/sacred_geometry.json", "as": "atlas/remote/rosetta/sacred_geometry.json" },
          { "remote": "schema/core.schema.json", "as": "atlas/remote/rosetta/core.schema.json" }
        ],
        "exports": [
          { "local": "bridges/geobin-bridges.json", "as": "bridges/geobin-bridges.json" },
          { "local": "glyph_to_geometric_bridge.json", "as": "glyph_to_geometric_bridge.json" },
          { "local": "Silicon/fabrication_pathway_schema.json", "as": "Silicon/fabrication_pathway_schema.json" },
          { "local": "Silicon/octahedral_state_encoder.json", "as": "Silicon/octahedral_state_encoder.json" }
        ],
        "consent": { "license": "CC-BY-4.0", "share_ok": true }
      },
      {
        "name": "polyhedral",
        "repo": "https://github.com/JinnZ2/Polyhedral-Intelligence",
        "ref": "main",
        "paths": [
          "glyphs/**/*.json",
          "atlas/shapes.json",
          "scrolls/*.md"
        ],
        "mounts": [
          { "remote": "atlas/shapes.json", "as": "atlas/remote/polyhedral/shapes.json" }
        ],
        "consent": { "license": "CC-BY-4.0", "share_ok": true }
      },
      {
        "name": "emotions",
        "repo": "https://github.com/JinnZ2/Emotions-as-Sensors",
        "ref": "main",
        "paths": [
          "sensors/**/*.json",
          "glyphs/**/*.json",
          "atlas/**/*.json"
        ],
        "consent": { "license": "MIT", "share_ok": true }
      },
      {
        "name": "defense",
        "repo": "https://github.com/JinnZ2/Symbolic-Defense-Protocol",
        "ref": "main",
        "paths": [
          "defenses/**/*.json",
          "protocols/**/*.json"
        ],
        "consent": { "license": "MIT", "share_ok": true }
      },
      {
        "name": "biogrid",
        "repo": "https://github.com/JinnZ2/BioGrid2.0",
        "ref": "main",
        "paths": [
          "planned/glyphs/atlas.json",
          "registry/atlas.glyphs.json"
        ],
        "mounts": [
          { "remote": "planned/glyphs/atlas.json", "as": "atlas/remote/biogrid/planned.json" },
          { "remote": "registry/atlas.glyphs.json", "as": "atlas/remote/biogrid/registry.json" }
        ],
        "consent": { "license": "CC-BY-4.0", "share_ok": true }
      }
    ],

    "local_manifests": [
      "bridges/**/*.json",
      "atlas/**/*.json",
      "schemas/**/*.json"
    ],

    "merge": {
      "order": ["local", "rosetta", "polyhedral", "emotions", "defense", "biogrid"],
      "strategy": "deep-merge"
    },

    "offline": false,
    "cache_dir": ".fieldcache",
    "integrity": { "enabled": true, "hash": "sha256", "allow_missing": false },
    "consent": { "license": "CC-BY-4.0", "share_ok": true, "redact_rules": ["**/private/**", "*.secrets.json"] }
  }
}
